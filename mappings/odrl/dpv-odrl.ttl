@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix dpv: <https://w3id.org/dpv#> .
@prefix tech: <https://w3id.org/dpv/tech#> .
@prefix pd: <https://w3id.org/dpv/pd#> .
@prefix loc: <https://w3id.org/dpv/loc#> .
@prefix legal-eu: <https://w3id.org/dpv/legal/eu#> .
@prefix eu-gdpr: <https://w3id.org/dpv/legal/eu/gdpr#> .
@prefix risk: <https://w3id.org/dpv/risk#> .
@prefix justifications: <https://w3id.org/dpv/justifications#> .
@prefix ai: <https://w3id.org/dpv/ai#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

@prefix dpv-odrl: <https://w3id.org/dpv/mappings/odrl#> .

# DPV entities - ODRL mapping #

dpv-odrl:Entity a odrl:Party, skos:Concept, odrl:LeftOperand ;
	skos:broader dpv:Entity .

dpv-odrl:Agent a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Agent .

dpv-odrl:LegalEntity a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:LegalEntity .

dpv-odrl:HumanSubject a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:HumanSubject .

dpv-odrl:Organisation a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Organisation .

dpv-odrl:Recipient a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Recipient ;
	skos:broader odrl:recipient .

dpv-odrl:Actor a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, tech:Actor .

# DPV processing - ODRL action mapping #

dpv-odrl:Processing a odrl:Action, skos:Concept ;
	skos:broader dpv:Processing .

dpv-odrl:Tracking a odrl:Action, skos:Concept ;
	skos:broader dpv:Tracking ;
	skos:related odrl:acceptTracking .

dpv-odrl:Aggregate a odrl:Action, skos:Concept ;
	skos:broader dpv:Aggregate ;
	skos:related odrl:aggregate .

dpv-odrl:Anonymise a odrl:Action, skos:Concept ;
	skos:broader dpv:Anonymise ;
	skos:related odrl:anonymize .

dpv-odrl:Delete a odrl:Action, skos:Concept ;
	skos:broader dpv:Delete ;
	skos:related odrl:delete .

dpv-odrl:Derive a odrl:Action, skos:Concept ;
	skos:broader dpv:Derive ;
	skos:related odrl:derive .

dpv-odrl:Display a odrl:Action, skos:Concept ;
	skos:broader dpv:Display ;
	skos:related odrl:display .

dpv-odrl:Modify a odrl:Action, skos:Concept ;
	skos:broader dpv:Modify ;
	skos:related odrl:modify .

dpv-odrl:Move a odrl:Action, skos:Concept ;
	skos:broader dpv:Move ;
	skos:related odrl:move .

dpv-odrl:Transfer a odrl:Action, skos:Concept ;
	skos:broader dpv:Transfer ;
	skos:related odrl:transfer .

dpv-odrl:Transform a odrl:Action, skos:Concept ;
	skos:broader dpv:Transform ;
	skos:related odrl:transform .

dpv-odrl:Use a odrl:Action, skos:Concept ;
	skos:broader dpv:Use ;
	skos:related odrl:use .

# DPV data - ODRL mapping #

dpv-odrl:Data a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:broader dpv:Data .

dpv-odrl:PersonalData a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:broader dpv:PersonalData .

dpv-odrl:Age a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:broader pd:Age .

dpv-odrl:Gender a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:broader pd:Gender .

dpv-odrl:Nationality a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:broader pd:Nationality .

dpv-odrl:DataSource a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:DataSource .

# DPV tech - ODRL mapping #

dpv-odrl:Technology a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:broader dpv:Technology .

# DPV purpose - ODRL left operand mapping #

dpv-odrl:Purpose a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Purpose ;
	skos:broader odrl:purpose .

# DPV TOMs - ODRL left operand mapping #

dpv-odrl:TechnicalOrganisationalMeasure a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:TechnicalOrganisationalMeasure .

dpv-odrl:TechnicalMeasure a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:TechnicalMeasure .

dpv-odrl:OrganisationalMeasure a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:OrganisationalMeasure .

dpv-odrl:LegalMeasure a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:LegalMeasure .

dpv-odrl:PhysicalMeasure a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:PhysicalMeasure .

dpv-odrl:RiskMitigationMeasure a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:RiskMitigationMeasure .

# DPV location - ODRL left operand mapping #

dpv-odrl:Location a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Location ;
	skos:broader odrl:spatial .

# DPV law & legal basis - ODRL left operand mapping #

dpv-odrl:Law a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Law .

dpv-odrl:LegalBasis a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:LegalBasis .

dpv-odrl:ConsentControl a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:ConsentControl .

dpv-odrl:ContractControl a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:ContractControl .

# DPV duration & frequency - ODRL left operand mapping #

dpv-odrl:Duration a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Duration ;
	skos:related odrl:elapsedTime, odrl:count .

dpv-odrl:Frequency a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Frequency ;
	skos:related odrl:timeInterval .

# DPV rights and justifications - ODRL left operand mapping #

dpv-odrl:Right a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Right .

dpv-odrl:Justification a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Justification .

# DPV risk - ODRL left operand mapping #

dpv-odrl:Risk a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Risk .

dpv-odrl:RiskLevel a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:RiskLevel .

dpv-odrl:RiskControl a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:RiskControl .

dpv-odrl:Likelihood a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Likelihood .

dpv-odrl:Severity a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Severity .

dpv-odrl:Consequence a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Consequence .

dpv-odrl:Impact a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Impact .

# DPV sector - ODRL left operand mapping #

dpv-odrl:Sector a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Sector .

# DPV status - ODRL left operand mapping #

dpv-odrl:Status a odrl:LeftOperand, owl:NamedIndividual, skos:Concept, dpv:Status .

# DPV rules - ODRL mapping #

dpv:Permission skos:related odrl:Permission .

dpv:Prohibition skos:related odrl:Prohibition .

dpv:Obligation skos:related odrl:Duty .

# DPV contractual clauses, legal agreements & policies - ODRL mapping #

dpv-odrl:ContractAmendmentClause a rdfs:Class , owl:Class, skos:Concept, dpv:ContractAmendmentClause ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractConfidentialityClause, dpv-odrl:ContractDisputeResolutionClause,
	dpv-odrl:ContractJurisdictionClause, dpv-odrl:ContractTerminationClause,
	dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause, dpv-odrl:LegalAgreement,
	dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:ContractConfidentialityClause a rdfs:Class , owl:Class, skos:Concept, dpv:ContractConfidentialityClause ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractDisputeResolutionClause,
	dpv-odrl:ContractJurisdictionClause, dpv-odrl:ContractTerminationClause,
	dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause, dpv-odrl:LegalAgreement,
	dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:ContractDisputeResolutionClause a rdfs:Class , owl:Class, skos:Concept, dpv:ContractDisputeResolutionClause ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractJurisdictionClause, dpv-odrl:ContractTerminationClause,
	dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause, dpv-odrl:LegalAgreement,
	dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:ContractJurisdictionClause a rdfs:Class , owl:Class, skos:Concept, dpv:ContractJurisdictionClause ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractDisputeResolutionClause, dpv-odrl:ContractTerminationClause,
	dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause, dpv-odrl:LegalAgreement,
	dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:ContractTerminationClause a rdfs:Class , owl:Class, skos:Concept, dpv:ContractTerminationClause ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractDisputeResolutionClause, dpv-odrl:ContractJurisdictionClause,
	dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause, dpv-odrl:LegalAgreement,
	dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:TermsOfService a rdfs:Class , owl:Class, skos:Concept, dpv:TermsOfService ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractDisputeResolutionClause, dpv-odrl:ContractJurisdictionClause,
	dpv-odrl:ContractTerminationClause, dpv-odrl:DataHandlingClause, dpv-odrl:LegalAgreement,
	dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:DataHandlingClause a rdfs:Class , owl:Class, skos:Concept, dpv:DataHandlingClause ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractDisputeResolutionClause, dpv-odrl:ContractJurisdictionClause,
	dpv-odrl:ContractTerminationClause, dpv-odrl:TermsOfService, dpv-odrl:LegalAgreement,
	dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:LegalAgreement a rdfs:Class , owl:Class, skos:Concept, dpv:LegalAgreement ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractDisputeResolutionClause, dpv-odrl:ContractJurisdictionClause,
	dpv-odrl:ContractTerminationClause, dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause,
	dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:ConfidentialityAgreement a rdfs:Class , owl:Class, skos:Concept, dpv:ConfidentialityAgreement ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractDisputeResolutionClause, dpv-odrl:ContractJurisdictionClause,
	dpv-odrl:ContractTerminationClause, dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause,
	dpv-odrl:LegalAgreement, dpv-odrl:NDA, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:NDA a rdfs:Class , owl:Class, skos:Concept, dpv:NDA ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractDisputeResolutionClause, dpv-odrl:ContractJurisdictionClause,
	dpv-odrl:ContractTerminationClause, dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause,
	dpv-odrl:LegalAgreement, dpv-odrl:ConfidentialityAgreement, dpv-odrl:StatisticalConfidentialityAgreement .

dpv-odrl:StatisticalConfidentialityAgreement a rdfs:Class , owl:Class, skos:Concept, dpv:StatisticalConfidentialityAgreement ;
	rdfs:subClassOf odrl:Policy ;
	owl:disjointWith odrl:Agreement, odrl:Offer, odrl:Privacy, odrl:Request, odrl:Ticket, odrl:Assertion,
	dpv-odrl:ContractAmendmentClause, dpv-odrl:ContractConfidentialityClause,
	dpv-odrl:ContractDisputeResolutionClause, dpv-odrl:ContractJurisdictionClause,
	dpv-odrl:ContractTerminationClause, dpv-odrl:TermsOfService, dpv-odrl:DataHandlingClause,
	dpv-odrl:LegalAgreement, dpv-odrl:ConfidentialityAgreement, dpv-odrl:NDA .