@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix dpv: <https://w3id.org/dpv#> .
@prefix tech: <https://w3id.org/dpv/tech#> .
@prefix pd: <https://w3id.org/dpv/pd#> .
@prefix loc: <https://w3id.org/dpv/loc#> .
@prefix legal-eu: <https://w3id.org/dpv/legal/eu#> .
@prefix eu-gdpr: <https://w3id.org/dpv/legal/eu/gdpr#> .
@prefix risk: <https://w3id.org/dpv/risk#> .
@prefix justifications: <https://w3id.org/dpv/justifications#> .
@prefix ai: <https://w3id.org/dpv/ai#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

@prefix dpv-odrl: <https://w3id.org/dpv/mappings/odrl#> .

# DPV entities - ODRL mapping #

dpv-odrl:Entity a odrl:Party, odrl:LeftOperand, skos:Concept ;
	skos:exactMatch dpv:Entity ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:Agent a odrl:Party, odrl:LeftOperand, skos:Concept ;
	skos:exactMatch dpv:Agent ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:LegalEntity a odrl:Party, odrl:LeftOperand, skos:Concept ;
	skos:exactMatch dpv:LegalEntity ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:HumanSubject a odrl:Party, odrl:LeftOperand, skos:Concept ;
	skos:exactMatch dpv:HumanSubject ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:Organisation a odrl:Party, odrl:LeftOperand, skos:Concept ;
	skos:exactMatch dpv:Organisation ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:Recipient a odrl:Party, odrl:LeftOperand, skos:Concept ;
	skos:exactMatch dpv:Recipient ;
	skos:broader odrl:recipient ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:Actor a odrl:Party, odrl:LeftOperand, skos:Concept ;
	skos:exactMatch tech:Actor ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

### All other entity concepts should be added 
### dpv-odrl:Patient a odrl:Party, skos:Concept ;
### 	skos:exactMatch dpv:Patient .

# DPV processing - ODRL action mapping #

dpv-odrl:Processing a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Processing .

dpv-odrl:Tracking a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Tracking ;
	skos:related odrl:acceptTracking .

dpv-odrl:Aggregate a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Aggregate ;
	skos:related odrl:aggregate .

dpv-odrl:Anonymise a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Anonymise ;
	skos:related odrl:anonymize .

dpv-odrl:Delete a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Delete ;
	skos:related odrl:delete .

dpv-odrl:Derive a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Derive ;
	skos:related odrl:derive .

dpv-odrl:Display a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Display ;
	skos:related odrl:display .

dpv-odrl:Modify a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Modify ;
	skos:related odrl:modify .

dpv-odrl:Move a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Move ;
	skos:related odrl:move .

dpv-odrl:Transfer a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Transfer ;
	skos:related odrl:transfer .

dpv-odrl:Transform a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Transform ;
	skos:related odrl:transform .

dpv-odrl:Use a odrl:Action, skos:Concept ;
	skos:exactMatch dpv:Use ;
	skos:related odrl:use .

### All other processing concepts should be added 
### dpv-odrl:Collect a odrl:Action, skos:Concept ;
### 	skos:exactMatch dpv:Collect .

# DPV data - ODRL mapping #

dpv-odrl:Data a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:exactMatch dpv:Data ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:PersonalData a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:exactMatch dpv:PersonalData ;
	skos:note "Only the odrl:isA, odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:Age a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:exactMatch pd:Age ;
	skos:note "Only the odrl:eq, odrl:gt, odrl:gteq, odrl:lt, odrl:lteq, and odrl:neq operators MUST be used."@en .

dpv-odrl:Gender a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:exactMatch pd:Gender ;
	skos:note "Only the odrl:eq and odrl:neq operators MUST be used."@en .

dpv-odrl:Nationality a odrl:Asset, skos:Concept, odrl:LeftOperand ;
	skos:exactMatch pd:Nationality ;
	skos:note "Only the odrl:eq, odrl:neq, odrl:isAnyOf, and odrl:isNoneOf operators MUST be used."@en .

dpv-odrl:DataSource a odrl:LeftOperand, skos:Concept ;
	skos:exactMatch dpv:DataSource ;
	skos:note "Only the odrl:isA, odrl:eq, and odrl:neq operators MUST be used."@en .

### All other data concepts should be added 
### dpv-odrl:Name a odrl:Asset, skos:Concept ;
### 	skos:exactMatch pd:Name .

